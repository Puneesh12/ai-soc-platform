<group name="custom_siem_lab">

  <rule id="100001" level="10">
    <if_group>syslog</if_group>
    <match>useradd|adduser</match>
    <description>New user account created</description>
    <mitre><id>T1136</id></mitre>
  </rule>

  <rule id="100002" level="12">
    <if_group>syslog</if_group>
    <match>usermod|added to group sudo|added to group admin</match>
    <description>User added to privileged group</description>
    <mitre><id>T1098</id></mitre>
  </rule>

  <rule id="100003" level="10" frequency="5" timeframe="60">
    <if_matched_group>authentication_failed</if_matched_group>
    <description>Brute force attack detected</description>
    <mitre><id>T1110</id></mitre>
  </rule>

  <rule id="100004" level="10">
    <if_group>syslog</if_group>
    <match>base64 -d|base64 --decode</match>
    <description>Encoded command execution detected</description>
    <mitre><id>T1059</id></mitre>
  </rule>

  <rule id="100005" level="14">
    <if_group>syslog</if_group>
    <match>/etc/shadow|/etc/passwd|mimikatz</match>
    <description>Credential dumping attempt detected</description>
    <mitre><id>T1003</id></mitre>
  </rule>

  <rule id="100006" level="8">
    <if_group>syslog</if_group>
    <match>crontab|cron.d</match>
    <description>Scheduled task created</description>
    <mitre><id>T1053</id></mitre>
  </rule>

  <rule id="100007" level="8">
    <if_group>syslog</if_group>
    <match>account locked|too many failures|pam_tally</match>
    <description>Account lockout detected</description>
    <mitre><id>T1110</id></mitre>
  </rule>

  <rule id="100008" level="6">
    <if_group>authentication_success</if_group>
    <time>6 pm - 8 am</time>
    <description>Login outside business hours detected</description>
    <mitre><id>T1021</id></mitre>
  </rule>

  <rule id="100009" level="12" frequency="10" timeframe="120">
    <if_matched_group>authentication_failed</if_matched_group>
    <same_source_ip/>
    <description>Password spray attack detected</description>
    <mitre><id>T1110.003</id></mitre>
  </rule>

  <rule id="100010" level="8">
    <if_group>syslog</if_group>
    <match>systemctl enable|insserv</match>
    <description>New service installed or enabled</description>
    <mitre><id>T1543</id></mitre>
  </rule>

  <rule id="100011" level="10">
    <if_group>syslog</if_group>
    <match>userdel|deluser</match>
    <description>User account deleted</description>
    <mitre><id>T1531</id></mitre>
  </rule>

  <rule id="100012" level="12">
    <if_group>syslog</if_group>
    <match>ufw disable|iptables -F</match>
    <description>Firewall disabled or flushed</description>
    <mitre><id>T1562</id></mitre>
  </rule>

  <rule id="100013" level="10">
    <if_group>syslog</if_group>
    <match>ssh.*-o StrictHostKeyChecking|scp|rsync.*password</match>
    <description>Lateral movement attempt detected</description>
    <mitre><id>T1021</id></mitre>
  </rule>

  <rule id="100014" level="10">
    <if_group>syslog</if_group>
    <match>wget|curl.*-o|certutil|bitsadmin</match>
    <description>File download tool executed</description>
    <mitre><id>T1105</id></mitre>
  </rule>

  <rule id="100015" level="10">
    <if_group>syslog</if_group>
    <match>.bashrc|.bash_profile|/etc/rc.local</match>
    <description>Persistence via startup file modification</description>
    <mitre><id>T1547</id></mitre>
  </rule>

  <rule id="100016" level="14">
    <if_group>syslog</if_group>
    <match>ptrace|LD_PRELOAD</match>
    <description>Process injection technique detected</description>
    <mitre><id>T1055</id></mitre>
  </rule>

  <rule id="100017" level="6">
    <if_group>syslog</if_group>
    <match>uname -a|whoami|hostname</match>
    <description>System reconnaissance detected</description>
    <mitre><id>T1082</id></mitre>
  </rule>

  <rule id="100018" level="14">
    <if_group>syslog</if_group>
    <match>vssadmin delete|wbadmin delete|bcdedit</match>
    <description>Backup deletion attempt detected</description>
    <mitre><id>T1490</id></mitre>
  </rule>

  <rule id="100019" level="10">
    <if_group>syslog</if_group>
    <match>sudo.*-s|sudo.*-i|sudo su|pkexec</match>
    <description>Privilege escalation via sudo detected</description>
    <mitre><id>T1548</id></mitre>
  </rule>

  <rule id="100020" level="10">
    <if_sid>504</if_sid>
    <description>Wazuh agent disconnected - possible tampering</description>
    <mitre><id>T1562</id></mitre>
  </rule>

</group>
