{
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "wazuh-alerts-ingest",
        "options": {}
      },
      "name": "Webhook Ingestion Hook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [100, 300]
    },
    {
      "parameters": {
        "rules": {
          "values": [
            {
              "value1": "={{ $json.body.rule.level }}",
              "operation": "largerEqual",
              "value2": 12,
