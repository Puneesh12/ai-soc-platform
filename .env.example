# ==============================================================================
# AI-Driven SOAR Platform - Environment Variable Template
# Copy this file to '.env' and populate with your live credentials.
# Do NOT commit your actual '.env' file containing real secrets to Git.
# ==============================================================================

# 🌐 Google Cloud Platform Configuration
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=asia-south1

# 🛡️ Wazuh SIEM Hub Settings
WAZUH_API_URL=https://localhost:55000
WAZUH_API_USER=wazuh-api-username
WAZUH_API_PASS=wazuh-api-password

# 🔍 Threat Intelligence Core
ABUSEIPDB_API_KEY=your_abuseipdb_api_key_here

# 🤖 Generative AI Engine (Groq / Llama-3)
GROQ_API_KEY=gsk_your_groq_api_key_here

# 📧 Enterprise Dispatch Interface (Gmail OAuth 2.0 / App Password)
SMTP_EMAIL=engpuneesh@gmail.com
GCP_OAUTH_CLIENT_ID=your_gcp_oauth_client_id_here
GCP_OAUTH_CLIENT_SECRET=your_gcp_oauth_client_secret_here
